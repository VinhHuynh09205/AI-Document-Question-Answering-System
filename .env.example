APP_NAME=AIChatBox
APP_ENV=development
API_V1_PREFIX=/api/v1
API_HOST_PORT=8000
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
GOOGLE_API_KEY=
GEMINI_MODEL=gemini-2.0-flash
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
EMBEDDINGS_MODEL=text-embedding-3-small
LOCAL_SEMANTIC_EMBEDDINGS=false
LOCAL_SEMANTIC_MODEL_NAME=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2
LOCAL_SEMANTIC_NORMALIZE_EMBEDDINGS=true
VECTOR_STORE_PATH=data/faiss_index
VECTOR_BACKUP_DIR=data/faiss_backups
UPLOAD_DIR=data/uploads
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=aichatbox
PG_USER=aichatbox
PG_PASSWORD=aichatbox
USERS_FILE_PATH=data/users.json
SUPPORTED_UPLOAD_EXTENSIONS=.pdf,.doc,.docx,.xlsx,.pptx,.html,.htm,.json,.xml,.txt,.md,.csv
REPLACE_EXISTING_DOCUMENTS_ON_UPLOAD=true
AUTH_SECRET_KEY=change-me-in-production
ADMIN_SETUP_SECRET=
AUTH_TOKEN_EXPIRE_MINUTES=60
ENABLE_REGISTRATION=true
PASSWORD_RESET_EXPIRE_MINUTES=20
PASSWORD_RESET_FRONTEND_URL=http://localhost:8000/login
OAUTH_GOOGLE_CLIENT_ID=
OAUTH_GOOGLE_CLIENT_SECRET=
OAUTH_GITHUB_CLIENT_ID=
OAUTH_GITHUB_CLIENT_SECRET=
OAUTH_ALLOWED_REDIRECT_BASE=http://localhost:8000
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
TOP_K=4
MIN_CONTEXT_TOKEN_OVERLAP=0.2
MIN_RELEVANT_CHUNKS=1
MAX_ANSWER_CHARS=1200
INGESTION_MAX_FILE_WORKERS=4
EMBEDDING_BATCH_SIZE=128
UPLOAD_JOB_RETENTION_SECONDS=3600
UPLOAD_JOB_MAX_RETRIES=3
UPLOAD_JOB_WORKER_POLL_SECONDS=0.8
UPLOAD_JOB_STALE_PROCESSING_SECONDS=120
LOG_LEVEL=INFO
RATE_LIMIT_WINDOW_SECONDS=60
LOGIN_RATE_LIMIT_PER_WINDOW=20
REGISTER_RATE_LIMIT_PER_WINDOW=10
ASK_RATE_LIMIT_PER_WINDOW=60
UPLOAD_RATE_LIMIT_PER_WINDOW=30
CORS_ALLOW_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
CORS_ALLOW_CREDENTIALS=true
CORS_ALLOW_METHODS=GET,POST,OPTIONS
CORS_ALLOW_HEADERS=*
ENABLE_SECURITY_HEADERS=true
ENABLE_HSTS=false

# Suggested profile defaults
# DEVELOPMENT
# APP_ENV=development
# LOG_LEVEL=INFO
# RATE_LIMIT_WINDOW_SECONDS=60
# ASK_RATE_LIMIT_PER_WINDOW=120
# UPLOAD_RATE_LIMIT_PER_WINDOW=60
# ENABLE_HSTS=false

# STAGING
# APP_ENV=staging
# LOG_LEVEL=INFO
# RATE_LIMIT_WINDOW_SECONDS=60
# ASK_RATE_LIMIT_PER_WINDOW=60
# UPLOAD_RATE_LIMIT_PER_WINDOW=30

# PRODUCTION
# APP_ENV=production
# LOG_LEVEL=WARNING
# RATE_LIMIT_WINDOW_SECONDS=60
# ASK_RATE_LIMIT_PER_WINDOW=30
# UPLOAD_RATE_LIMIT_PER_WINDOW=15
# ENABLE_HSTS=true
